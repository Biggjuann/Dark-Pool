# Dark Pool Tracker — backend environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored; never commit real credentials.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# SQLAlchemy connection string.
# SQLite (default, no extra setup required):
DATABASE_URL=sqlite:///./darkpool.db

# PostgreSQL example (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/darkpool

# ---------------------------------------------------------------------------
# Discord alerts
# ---------------------------------------------------------------------------

# Webhook URL for high-conviction signal notifications.
# Leave blank to disable Discord alerts.
# Create a webhook: Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------

# Comma-separated list of allowed frontend origins.
# Defaults to localhost:3000 and localhost:5173 (Vite dev server).
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------------------
# Debug / logging
# ---------------------------------------------------------------------------

# Set to 1 to echo every SQL statement to stdout (verbose, dev only).
SQL_ECHO=0

# ---------------------------------------------------------------------------
# FINRA Developer API  (https://developer.finra.org)
# ---------------------------------------------------------------------------

# Used by POST /api/ingest/fetch to download weekly REGSHODAILY data.
# Register for free at developer.finra.org, create an API application,
# and copy the Client ID and Client Secret here.
FINRA_CLIENT_ID=
FINRA_CLIENT_SECRET=
